# Copia este ficheiro para `android/keystore.properties` antes do build de release.
# Mantem o ficheiro real fora do Git.
KASTROZAPP_UPLOAD_STORE_FILE=app/kastrozapp-upload.jks
KASTROZAPP_UPLOAD_STORE_PASSWORD=troca-esta-password
KASTROZAPP_UPLOAD_KEY_ALIAS=kastrozapp-upload
KASTROZAPP_UPLOAD_KEY_PASSWORD=troca-esta-password
ANDROID_VERSION_CODE=1
ANDROID_VERSION_NAME=1.0.0
