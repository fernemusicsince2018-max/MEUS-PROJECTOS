# Producao remota para web + app nativo.
# Usa este ficheiro como base para `.env.production.local`
# ou para preencher as variaveis do provider remoto.

# Frontend / runtime
VITE_CATALOG_API_BASE=/api
VITE_NATIVE_CATALOG_API_BASE=https://catalogofernagest.com/api
VITE_PUBLIC_CATALOG_BASE_URL=https://catalogofernagest.com
VITE_PUBLIC_CATALOG_BASE_DOMAIN=catalogofernagest.com
VITE_ALLOW_LOCAL_FALLBACK=false

# Backend / sessao / CORS
APP_BASE_URL=https://catalogofernagest.com
CORS_ALLOWED_ORIGINS=capacitor://localhost,http://localhost,https://*.catalogofernagest.com
SESSION_COOKIE_SAME_SITE=None
SESSION_COOKIE_SECURE=true
SUPER_ADMIN_EMAILS=admin@catalogofernagest.com

# PostgreSQL serverless
POSTGRES_POOLER_URL=postgres://user:password@pooler-host:6543/catalogo_prod?sslmode=require
POSTGRES_USE_POOLER=true
POSTGRES_POOL_MAX=3
POSTGRES_IDLE_TIMEOUT_MS=10000
POSTGRES_CONNECTION_TIMEOUT_MS=10000
POSTGRES_QUERY_TIMEOUT_MS=0
POSTGRES_STATEMENT_TIMEOUT_MS=0
POSTGRES_POOL_MAX_USES=0
POSTGRES_KEEPALIVE=true
POSTGRES_KEEPALIVE_INITIAL_DELAY_MS=0
POSTGRES_ALLOW_EXIT_ON_IDLE=false
POSTGRES_APPLICATION_NAME=kastrozap-production
SYSTEM_SETTINGS_CACHE_TTL_MS=10000
PUBLIC_CATALOG_CACHE_TTL_MS=45000
PUBLIC_CATALOG_CACHE_STALE_WHILE_REVALIDATE_SECONDS=180

# Email / reset de senha
PASSWORD_RESET_FROM_NAME=KASTROZAPP
PASSWORD_RESET_FROM_EMAIL=no-reply@catalogofernagest.com
PASSWORD_RESET_REPLY_TO=suporte@catalogofernagest.com
RESEND_API_KEY=re_prod_xxxxxxxxxxxxx
CATALOG_EXPOSE_RESET_CODE=false

# WhatsApp Cloud API
WHATSAPP_CLOUD_API_TOKEN=EAAGprodxxxxxxxxxxxxx
WHATSAPP_CLOUD_PHONE_NUMBER_ID=123456789012345
WHATSAPP_CLOUD_API_VERSION=v23.0
WHATSAPP_CLOUD_TEMPLATE_LANGUAGE=pt_PT
WHATSAPP_CLOUD_ORDER_SUMMARY_TEMPLATE_NAME=catalog_order_summary_v1
WHATSAPP_CLOUD_ORDER_ITEM_TEMPLATE_NAME=catalog_order_item_image_v1

# Dispatcher da fila de notificacoes
NOTIFICATION_DISPATCH_SECRET=prod-notify-secret
NOTIFICATION_JOB_BATCH_SIZE=20

# Storage / CDN
SUPABASE_URL=https://prod-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJprodxxxxxxxxxxxxx
SUPABASE_STORAGE_BUCKET=catalog-assets

# Branding opcional
VITE_BRAND_NAME=KASTROZAPP
VITE_BRAND_TAGLINE=Sua loja no WhatsApp.
VITE_BRAND_ACCENT=#25ae82
VITE_BRAND_DARK=#1b1c48
VITE_BRAND_HIGHLIGHT=#ffc61a
VITE_BRAND_LOGO_URL=/pwa-icon.svg
VITE_BRAND_INITIALS=KZ
