# Staging remoto para web + app nativo.
# Copia este ficheiro para `.env.staging.local` quando fores correr scripts locais
# contra o ambiente de staging, ou replica o mesmo bloco no provider remoto.

# Frontend / runtime
VITE_CATALOG_API_BASE=/api
VITE_NATIVE_CATALOG_API_BASE=https://staging.catalogofernagest.com/api
VITE_PUBLIC_CATALOG_BASE_URL=https://staging.catalogofernagest.com
VITE_PUBLIC_CATALOG_BASE_DOMAIN=staging.catalogofernagest.com
VITE_ALLOW_LOCAL_FALLBACK=false

# Backend / sessao / CORS
APP_BASE_URL=https://staging.catalogofernagest.com
CORS_ALLOWED_ORIGINS=capacitor://localhost,http://localhost,https://*.staging.catalogofernagest.com
SESSION_COOKIE_SAME_SITE=None
SESSION_COOKIE_SECURE=true
SUPER_ADMIN_EMAILS=admin@catalogofernagest.com

# PostgreSQL serverless
POSTGRES_POOLER_URL=postgres://user:password@pooler-host:6543/catalogo_staging?sslmode=require
POSTGRES_USE_POOLER=true
POSTGRES_POOL_MAX=3
POSTGRES_IDLE_TIMEOUT_MS=10000
POSTGRES_CONNECTION_TIMEOUT_MS=10000
POSTGRES_QUERY_TIMEOUT_MS=0
POSTGRES_STATEMENT_TIMEOUT_MS=0
POSTGRES_POOL_MAX_USES=0
POSTGRES_KEEPALIVE=true
POSTGRES_KEEPALIVE_INITIAL_DELAY_MS=0
POSTGRES_ALLOW_EXIT_ON_IDLE=false
POSTGRES_APPLICATION_NAME=kastrozap-staging
SYSTEM_SETTINGS_CACHE_TTL_MS=10000
PUBLIC_CATALOG_CACHE_TTL_MS=45000
PUBLIC_CATALOG_CACHE_STALE_WHILE_REVALIDATE_SECONDS=180

# Email / reset de senha
PASSWORD_RESET_FROM_NAME=KASTROZAPP STAGING
PASSWORD_RESET_FROM_EMAIL=no-reply@staging.catalogofernagest.com
PASSWORD_RESET_REPLY_TO=suporte@catalogofernagest.com
RESEND_API_KEY=re_staging_xxxxxxxxxxxxx
CATALOG_EXPOSE_RESET_CODE=false

# WhatsApp Cloud API
WHATSAPP_CLOUD_API_TOKEN=EAAGstagingxxxxxxxxxxxxx
WHATSAPP_CLOUD_PHONE_NUMBER_ID=123456789012345
WHATSAPP_CLOUD_API_VERSION=v23.0
WHATSAPP_CLOUD_TEMPLATE_LANGUAGE=pt_PT
WHATSAPP_CLOUD_ORDER_SUMMARY_TEMPLATE_NAME=catalog_order_summary_v1
WHATSAPP_CLOUD_ORDER_ITEM_TEMPLATE_NAME=catalog_order_item_image_v1

# Dispatcher da fila de notificacoes
NOTIFICATION_DISPATCH_SECRET=staging-notify-secret
NOTIFICATION_JOB_BATCH_SIZE=20

# Storage / CDN
SUPABASE_URL=https://staging-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJstagingxxxxxxxxxxxxx
SUPABASE_STORAGE_BUCKET=catalog-assets

# Branding opcional
VITE_BRAND_NAME=KASTROZAPP
VITE_BRAND_TAGLINE=Sua loja no WhatsApp.
VITE_BRAND_ACCENT=#25ae82
VITE_BRAND_DARK=#1b1c48
VITE_BRAND_HIGHLIGHT=#ffc61a
VITE_BRAND_LOGO_URL=/pwa-icon.svg
VITE_BRAND_INITIALS=KZ

# Runner local para load test em staging
LOADTEST_BASE_URL=https://staging.catalogofernagest.com
LOADTEST_MERCHANT_EMAIL=lojista-teste@catalogofernagest.com
LOADTEST_MERCHANT_PASSWORD=SenhaForte123
LOADTEST_SUPER_ADMIN_EMAIL=admin@catalogofernagest.com
LOADTEST_SUPER_ADMIN_PASSWORD=SenhaForte123
LOADTEST_REPORT_LABEL=staging-load-test
LOADTEST_SEED_PRODUCT_COUNT=300
LOADTEST_PREFILL_ORDERS=1000
LOADTEST_SCENARIOS=all
LOADTEST_PRIVATE_SESSION_POOL_SIZE=4
LOADTEST_TIMEOUT_MS=30000
LOADTEST_TARGETS=1000,5000,10000
LOADTEST_MERCHANT_PAGE_LIMITS=50
LOADTEST_STAGE_RATIOS=0.1,0.25,0.5,1
LOADTEST_STAGE_DURATIONS=15,20,20,30
LOADTEST_MAX_WORKERS=24
LOADTEST_CATALOG_TARGET_FACTOR=1
LOADTEST_ORDER_TARGET_FACTOR=1
LOADTEST_MERCHANT_TARGET_FACTOR=0.1
LOADTEST_CATALOG_TARGET_CONCURRENCY_PER_WORKER=125
LOADTEST_ORDER_TARGET_CONCURRENCY_PER_WORKER=100
LOADTEST_MERCHANT_TARGET_CONCURRENCY_PER_WORKER=75
